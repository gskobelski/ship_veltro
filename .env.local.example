# Project URL (widoczny publicznie — OK w kodzie klienta)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# anon/public key (widoczny publicznie — OK w kodzie klienta)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role key — TYLKO SERVER SIDE, nigdy nie commituj do gita!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────────
# Site URL — zmień na domenę produkcyjną na Vercel
